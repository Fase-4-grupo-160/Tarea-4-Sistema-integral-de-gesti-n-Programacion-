''' El trabajo debe basarse en una arquitectura orientada a objetos, incluyendo al menos:
• Una clase abstracta que represente entidades generales del sistema.
• Una clase Cliente con validaciones robustas y encapsulación de datos personales.
• Una clase abstracta Servicio y al menos tres servicios especializados que hereden de ella, implementando polimorfismo y
métodos sobrescritos para calcular costos, describir servicios y
 alidar parámetros.
• Una clase Reserva que integre cliente, servicio, duración y estado, e implemente confirmación, cancelación y procesamiento con
manejo de excepciones.
• Métodos sobrecargados (por ejemplo, diferentes variantes del cálculo de costos con impuestos, descuentos o parámetros
opcionales).
•Un archivo de logs donde se registren todos los errores y eventos relevantes.
•El sistema, sin utilizar ningún motor de base de datos, debe simular al menos 10 operaciones completas, incluyendo registros válidos e
inválidos de clientes, creación correcta e incorrecta de servicios, y reservas exitosas y fallidas, demostrando la capacidad del programa
para continuar funcionando ante errores graves y manejar excepciones de manera controlada y profesional.
'''

import abc
import datetime
import logging
import tkinter as tk
from tkinter import scrolledtext

# Configuración de Logging para el sistema
logging.basicConfig(
    filename='software_fj_errors.log',
    level=logging.ERROR,
    format='%(asctime)s - %(levelname)s - %(message)s'
)

# --- 1. Excepciones Personalizadas ---
class BookingError(Exception):
    pass

class ServiceNotAvailableError(BookingError):
    pass

class InvalidDataError(BookingError):
    pass

# --- 2. Clase Abstracta General ---
class EntidadSistema(abc.ABC):
    def __init__(self, id_entidad):
        self._id_entidad = id_entidad

    @abc.abstractmethod
    def mostrar_info(self):
        pass

# --- 3. Clase Cliente ---
class Cliente(EntidadSistema):
    def __init__(self, id_entidad, nombre, email):
        super().__init__(id_entidad)
        self.set_nombre(nombre)
        self.email = email

    def set_nombre(self, nombre):
        if not nombre or len(nombre) < 2:
            logging.error(f"Intento de crear cliente con nombre inválido: {nombre}")
            raise InvalidDataError("El nombre del cliente no es válido.")
        self.__nombre = nombre

    def mostrar_info(self):
        return f"Cliente[{self._id_entidad}]: {self.__nombre} - {self.email}"

# --- 4. Clase Abstracta Servicio ---
class Servicio(EntidadSistema):
    def __init__(self, id_entidad, tarifa_base, nombre_servicio):
        super().__init__(id_entidad)
        self.tarifa_base = tarifa_base
        self.nombre_servicio = nombre_servicio
        self.disponible = True

    @abc.abstractmethod
    def calcular_costo(self):
        pass

    @abc.abstractmethod
    def describir_servicio(self):
        pass
 
    @abc.abstractmethod #segundo commit
    def validar_parametros(self):
        pass
        
# --- 5. Clases Derivadas de Servicio ---
class ReservaSala(Servicio):
    def __init__(self, id_entidad, tarifa_base, capacidad):
        super().__init__(id_entidad, tarifa_base, "Reserva de Sala")
        self.capacidad = capacidad

    def mostrar_info(self):
        return f"Servicio[{self._id_entidad}]: {self.nombre_servicio} para {self.capacidad} personas"

    def validar_parametros(self): #segundo commit
        if self.capacidad<=0:
            raise InvalidDataError("la capacidad de la sala debe ser mayor a 0.")
        print(f"parametros {self.id_entidad} validados correctamente.")
        
    def calcular_costo(self, horas=1):
        return (self.tarifa_base * horas) + (self.capacidad * 0.1)

    def describir_servicio(self):
        return f"{self.nombre_servicio} (Capacidad: {self.capacidad})"
        
class AlquilerEquipo(Servicio):
    def __init__(self, id_entidad, tarifa_base, tipo_equipo):
        super().__init__(id_entidad, tarifa_base, "Alquiler de Equipo")
        self.tipo_equipo = tipo_equipo

    def mostrar_info(self):
        return f"Servicio[{self._id_entidad}]: {self.nombre_servicio} - {self.tipo_equipo}"
    
    def validar_parametros(self): #segundo commit
        if not self.tipo_equipo:
            raise InvalidDataError("El tipo de equipo es obligatorio.")
        print(f"parametros de {self.id_entidad} validados correctamente.")
            
    def calcular_costo(self, dias=1, seguro=False):
        costo = self.tarifa_base * dias
        if seguro: costo += 50
        return costo

    def describir_servicio(self):
        return f"{self.nombre_servicio} - {self.tipo_equipo}"

class Asesoria(Servicio):
    def __init__(self, id_entidad, tarifa_base, nivel_especialidad):
        super().__init__(id_entidad, tarifa_base, "Asesoría Especializada")
        self.nivel_especialidad = nivel_especialidad

    def mostrar_info(self):
        return f"Servicio[{self._id_entidad}]: {self.nombre_servicio} Nivel {self.nivel_especialidad}"
    
    def validar_parametros(self): #segundo commit
        niveles_validos=["Junior", "Senior", "Expert"]
        if self.nivel_especialidad not in niveles_validos:
            raise InvalidDataError("f {self.nivel_especialidad} no es valido.")
        print(f"parametros de {self.id_entidad} validados correctamente.")  
        
    def calcular_costo(self, horas=1):
        if self.nivel_especialidad == "Senior":
            return (self.tarifa_base * horas) * 0.9
        return self.tarifa_base * horas

    def describir_servicio(self):
        return f"{self.nombre_servicio} ({self.nivel_especialidad})"

# --- 6. Clase Reserva ---
class Reserva:
    def __init__(self, cliente, servicio, fecha, output_widget):
        self.cliente = cliente
        self.servicio = servicio
        self.fecha = fecha
        self.estado = "Confirmada"
        self.out = output_widget # Referencia al widget de Tkinter

    def imprimir(self, texto):
        self.out.insert(tk.END, texto + "\n")
        self.out.see(tk.END)

    def procesar_reserva(self):
        try:
            if not self.servicio.disponible:
                raise ServiceNotAvailableError(f"Servicio {self.servicio.nombre_servicio} no disponible.")
            
            costo = self.servicio.calcular_costo()
            self.imprimir(f"Reserva exitosa: {self.cliente.mostrar_info()} -> "
                          f"{self.servicio.describir_servicio()}. Costo: ${costo:.2f}")

        except ServiceNotAvailableError as e:
           self.estado = "Fallida"
            logging.error(f"Error en reserva: {e}")
            self.imprimir(f"Error controlado: {e}")
        except Exception as e:
            logging.critical(f"Error inesperado: {e}", exc_info=True)
        finally:
            self.imprimir(f"Estado final de la operación: {self.estado}\n")

