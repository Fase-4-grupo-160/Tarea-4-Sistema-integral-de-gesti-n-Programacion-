    try:
        nombre = entry_nombre.get()
        email = entry_email.get()
        tipo_servicio = combo_servicio.get()
        fecha = entry_fecha.get()

        cliente = Cliente("C_GUI", nombre, email)

        if tipo_servicio == "Reserva Sala":
            servicio = ReservaSala("S_GUI", 100, 20)

        elif tipo_servicio == "Alquiler Equipo":
            servicio = AlquilerEquipo("S_GUI", 50, "Proyector")

        else:
            servicio = Asesoria("S_GUI", 200, "Senior")

        costo = servicio.calcular_costo()

        mostrar_mensaje("ok",
            f"Reserva Confirmada\n"
            f"Cliente: {nombre}\n"
            f"Servicio: {servicio.describir_servicio()}\n"
