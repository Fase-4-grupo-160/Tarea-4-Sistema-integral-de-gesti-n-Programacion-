# --- MENSAJES VISUALES ---
def mostrar_mensaje(tipo, texto):
    if tipo == "ok":
        txt_logs.insert(tk.END, "✔ ", "ok")
        txt_logs.insert(tk.END, texto + "\n\n", "ok")

    elif tipo == "error":
        txt_logs.insert(tk.END, "✖ ", "error")
        txt_logs.insert(tk.END, texto + "\n\n", "error")

    txt_logs.see(tk.END)

